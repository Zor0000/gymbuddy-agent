# ─── Neo4j Aura DB (Phase 0) ──────────────────────────────────────────
# From console.neo4j.io → create instance → download the credentials file.
# IMPORTANT: for AuraDB, USER and DATABASE are always 'neo4j'. The Aura file
# calls the user NEO4J_USERNAME — map it to NEO4J_USER here.
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_me
NEO4J_DATABASE=neo4j

# ─── Groq (custom agent LLM, FREE tier) ───────────────────────────────
# From console.groq.com → API Keys.
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# ─── HuggingFace (optional, speeds MiniLM download) ───────────────────
# From huggingface.co/settings/tokens (read scope). Model is public — skip if unsure.
HF_TOKEN=

# ─── Embeddings ───────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── Aura Agent platform LLM (Phase 7, choose ONE) ────────────────────
# Option A — Vertex AI (GCP free trial $300, 90 days):
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Option B — OpenAI ($5 free signup credit):
OPENAI_API_KEY=sk-replace_me

# ─── App ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
